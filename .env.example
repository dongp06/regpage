# ===========================================
# Facebook Page Reg & Transfer - Cau hinh (.env)
# ===========================================
# Sao chep file nay thanh .env va dien gia tri that:
#   cp .env.example .env
# ===========================================

# API key (bat buoc)
API_KEY=your_api_key_here

# Base URL API (tuy chon, mac dinh: https://minhdong.site/api/v1/facebook)
API_BASE_URL=https://minhdong.site/api/v1/facebook

# Nick goc (tao Page)
SOURCE_COOKIE=cookie_nick_goc_day_du
SOURCE_PASSWORD=mat_khau_nick_goc

# Nick nhan (nhan Page)
TARGET_UID=uid_nick_nhan
TARGET_COOKIE=cookie_nick_nhan_day_du
