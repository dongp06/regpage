# API key (bat buoc)
API_KEY=your_api_key_here

# Base URL API (tuy chon, mac dinh: https://minhdong.site/api/v1/facebook)
API_BASE_URL=https://minhdong.site/api/v1/facebook

# Nick goc (tao Page)
SOURCE_COOKIE=cookie_nick_goc_day_du
SOURCE_PASSWORD=mat_khau_nick_goc

# Nick nhan (nhan Page)
TARGET_UID=uid_nick_nhan
TARGET_COOKIE=cookie_nick_nhan_day_du

# ===== Token-based admin permissions =====
# Base URL API (cho che do Token)
BASE_URL=https://minhdong.site

# Facebook token (EAAG...)
TOKEN=your_facebook_token_here

# Profile ID cua Page
PROFILE_ID=profile_id_cua_page

# Password (dung cho add/remove admin)
PASSWORD=mat_khau_nick

# Invitee UID (dung cho accept/decline invitation)
INVITEE_UID=uid_nguoi_duoc_moi

# Ghi chu:
# - Che do "Reg & Transfer Page (Token) [Batch]" se hoi ban nhap danh sach PROFILE_ID khi chay (khong doc list tu .env).
